# ──────────────────────────────────────────────
# legalize-kr 환경변수 설정
# ──────────────────────────────────────────────
# 이 파일을 .env로 복사하고 값을 채워주세요.

# [필수] 국가법령정보 API OC 값
# 가입: https://open.law.go.kr/LSO/login.do
# 본인 이메일이 user@example.com이면 OC=user
LAW_API_OC=test

# [선택] 열린국회정보 API 인증키
# 발급: https://open.assembly.go.kr/portal/openapi/main.do
# 설정하면 발의의원 정보, 표결 기록을 함께 기록합니다.
ASSEMBLY_API_KEY=

# [선택] 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# [선택] API 요청 간 대기 시간 (초, 기본: 0.5)
REQUEST_DELAY=0.5

# [선택] GitHub 저장소 URL (RSS 피드 링크에 사용)
GITHUB_REPO_URL=https://github.com/YOUR_USERNAME/legalize-kr
